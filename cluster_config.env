# --- AI CLUSTER GLOBAL CONFIGURATION ---
CLUSTER_VERSION=1.0.0
PROJECT_ROOT_PATH=./

# --- DÜĞÜM (NODE) IP ADRESLERİ ---
NODE_MAIN_GPU_IP=192.168.50.1  # Şu an PC-1 (5060Ti) | İleride PC-3 (5090) buraya yazılacak
NODE_MEMORY_RAM_IP=192.168.50.2 # Şu an PC-2 (1650)   | İleride 5060Ti buraya kaydırılacak

# --- VERİTABANI VE ORTAK BELLEK AYARLARI ---
POSTGRES_DB=ai_knowledge_base
POSTGRES_USER=ai_admin
POSTGRES_PASSWORD=ai_secure_password
QDRANT_COLLECTION=cluster_global_memory
